#!/usr/bin/env python3
"""
git-backup

Watches configured directories and automatically commits/pushes changes to git
after a period of inactivity. Never pulls.

Linux only. Requires: python3-watchdog
"""

import argparse
import fnmatch
import json
import logging
import os
import signal
import subprocess
import sys
import threading
import time
from pathlib import Path

try:
    from watchdog.observers import Observer
    from watchdog.events import FileSystemEventHandler, FileSystemEvent
except ImportError:
    print("Error: python3-watchdog is required.", file=sys.stderr)
    print("  Install: sudo apt install python3-watchdog  (or: pip3 install watchdog)", file=sys.stderr)
    sys.exit(1)

DEFAULT_CONFIG_PATH = Path.home() / ".config" / "git-backup" / "config.json"
DEFAULT_DELAY = 300  # seconds


class GitBackup:
    def __init__(
        self,
        path: Path,
        delay_seconds: int,
        branch: str | None = None,
        exclude: list[str] | None = None,
    ):
        self.path = path.resolve()
        self.delay_seconds = delay_seconds
        self.branch = branch
        self.exclude = exclude or []
        self.timer: threading.Timer | None = None
        self.lock = threading.Lock()
        self.sync_lock = threading.Lock()
        self.logger = logging.getLogger(f"git-backup.{self.path.name}")

    def on_change(self, event: FileSystemEvent | None = None):
        """Called when a file system change is detected. Resets the debounce timer."""
        if event is not None:
            self.logger.debug(
                "on_change triggered: %s | src=%s | is_directory=%s",
                event.event_type,
                event.src_path,
                event.is_directory,
            )
        else:
            self.logger.debug("on_change triggered: startup sync (no event)")

        with self.lock:
            if self.timer is not None:
                self.logger.debug("Cancelling existing timer")
                self.timer.cancel()
            self.timer = threading.Timer(self.delay_seconds, self._commit)
            self.timer.daemon = True
            self.timer.start()
            self.logger.debug("Timer started: %ds", self.delay_seconds)

    def _commit(self):
        """Perform git add, commit (if needed), and push."""
        with self.lock:
            self.timer = None

        with self.sync_lock:
            self.logger.info("Running sync...")

            if not (self.path / ".git").exists():
                self.logger.error("Not a git repository, skipping: %s", self.path)
                return

            try:
                # Stage all changes (including deletes)
                self.logger.debug("Running: git add -A (cwd=%s)", self.path)
                add_result = subprocess.run(
                    ["git", "add", "-A"],
                    cwd=self.path,
                    check=True,
                    capture_output=True,
                    text=True,
                )
                if add_result.stdout:
                    self.logger.debug("git add stdout: %s", add_result.stdout.strip())
                if add_result.stderr:
                    self.logger.debug("git add stderr: %s", add_result.stderr.strip())

                # Check if there is anything staged
                self.logger.debug("Running: git diff --cached --quiet")
                diff_result = subprocess.run(
                    ["git", "diff", "--cached", "--quiet"],
                    cwd=self.path,
                    capture_output=True,
                    text=True,
                )
                if diff_result.returncode == 0:
                    self.logger.info("No changes to commit")
                    return
                else:
                    self.logger.debug("git diff --cached returned %d", diff_result.returncode)

                # Commit
                timestamp = time.strftime("%Y-%m-%d %H:%M:%S %z")
                commit_msg = f"auto-sync: {timestamp}"
                self.logger.debug("Running: git commit -m '%s'", commit_msg)
                commit_result = subprocess.run(
                    ["git", "commit", "-m", commit_msg],
                    cwd=self.path,
                    check=True,
                    capture_output=True,
                    text=True,
                )
                if commit_result.stdout:
                    self.logger.debug("git commit stdout: %s", commit_result.stdout.strip())
                if commit_result.stderr:
                    self.logger.debug("git commit stderr: %s", commit_result.stderr.strip())
                self.logger.info("Committed: %s", commit_msg)

                # Push (never pull)
                push_cmd = ["git", "push"]
                if self.branch:
                    push_cmd.extend(["origin", self.branch])
                self.logger.debug("Running: %s", " ".join(push_cmd))

                push_result = subprocess.run(
                    push_cmd,
                    cwd=self.path,
                    capture_output=True,
                    text=True,
                )
                if push_result.stdout:
                    self.logger.debug("git push stdout: %s", push_result.stdout.strip())
                if push_result.stderr:
                    self.logger.debug("git push stderr: %s", push_result.stderr.strip())
                if push_result.returncode == 0:
                    self.logger.info("Push successful")
                else:
                    self.logger.error("Push failed (rc=%d): %s", push_result.returncode, push_result.stderr.strip())

            except subprocess.CalledProcessError as e:
                err = (e.stderr or e.stdout or str(e)).strip()
                self.logger.error("Git command failed: %s", err)


class EventHandler(FileSystemEventHandler):
    def __init__(self, backup: GitBackup):
        self.backup = backup

    def _is_excluded(self, src_path: str) -> bool:
        if not self.backup.exclude:
            return False
        try:
            rel = Path(src_path).relative_to(self.backup.path)
        except ValueError:
            return False

        rel_str = str(rel)
        parts = rel.parts

        for pattern in self.backup.exclude:
            # Match the full relative path
            if fnmatch.fnmatch(rel_str, pattern):
                return True
            # Match any directory component
            for part in parts[:-1]:
                if fnmatch.fnmatch(part, pattern):
                    return True
            # Match the file / directory name itself
            if fnmatch.fnmatch(rel.name, pattern):
                return True

        return False

    def on_any_event(self, event: FileSystemEvent):
        self.backup.logger.debug(
            "Raw event: type=%s src=%s is_directory=%s",
            event.event_type,
            event.src_path,
            event.is_directory,
        )

        # Ignore git's own internals and temp files
        parts = Path(event.src_path).parts
        if ".git" in parts:
            self.backup.logger.debug("Ignored: path contains .git: %s", event.src_path)
            return
        if event.event_type in ("opened", "closed_no_write"):
            self.backup.logger.debug("Ignored: event type is '%s': %s", event.event_type, event.src_path)
            return
        if self._is_excluded(event.src_path):
            self.backup.logger.debug("Ignored: path excluded: %s", event.src_path)
            return

        self.backup.on_change(event)


def load_config(path: Path) -> dict:
    with open(path, "r", encoding="utf-8") as f:
        data = json.load(f)
    # Allow a top-level list as shorthand for directories
    if isinstance(data, list):
        return {"directories": data}
    return data


def setup_logging(verbose: bool):
    level = logging.DEBUG if verbose else logging.INFO
    logging.basicConfig(
        level=level,
        format="%(asctime)s [%(name)s] %(levelname)s: %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    )


def main():
    parser = argparse.ArgumentParser(
        description="Automatic git backup daemon (commit & push only, never pull)"
    )
    parser.add_argument(
        "-c", "--config", type=Path, default=DEFAULT_CONFIG_PATH,
        help="Path to config file (default: ~/.config/git-backup/config.json)"
    )
    parser.add_argument("-v", "--verbose", action="store_true", help="Verbose output")
    args = parser.parse_args()

    setup_logging(args.verbose)

    if not args.config.exists():
        logging.error("Config file not found: %s", args.config)
        logging.error("Create one or use --config to specify a path")
        sys.exit(1)

    try:
        config = load_config(args.config)
        logging.debug("Loaded config: %s", config)
    except (json.JSONDecodeError, OSError) as e:
        logging.error("Failed to load config: %s", e)
        sys.exit(1)

    default_delay = config.get("default_delay_seconds", DEFAULT_DELAY)
    directories = config.get("directories", [])
    logging.debug("default_delay_seconds=%s directories=%s", default_delay, directories)

    if not directories:
        logging.error("No directories configured")
        sys.exit(1)

    backups: list[GitBackup] = []
    observers: list[Observer] = []

    for idx, entry in enumerate(directories):
        if isinstance(entry, str):
            path = Path(entry).expanduser()
            delay = default_delay
            branch = None
        elif isinstance(entry, dict):
            path = Path(entry["path"]).expanduser()
            delay = entry.get("delay_seconds", default_delay)
            branch = entry.get("branch")
            exclude = entry.get("exclude")
            if exclude is not None and not isinstance(exclude, list):
                logging.warning(
                    "Invalid 'exclude' at index %d (must be a list), skipping: %r",
                    idx, entry,
                )
                continue
        else:
            logging.warning("Invalid config entry at index %d: %r", idx, entry)
            continue

        if not path.is_dir():
            logging.warning("Directory does not exist, skipping: %s", path)
            continue

        logging.debug(
            "Config entry %d: path=%s delay=%s branch=%s exclude=%s",
            idx, path, delay, branch, exclude,
        )

        backup = GitBackup(path, delay, branch, exclude)
        backups.append(backup)

        handler = EventHandler(backup)
        observer = Observer()
        try:
            observer.schedule(handler, str(path), recursive=True)
            observer.start()
            observers.append(observer)
        except OSError as e:
            logging.error("Failed to start watcher for %s: %s", path, e)
            continue

        logging.info(
            "Watching %s (delay=%ds branch=%s exclude=%r)",
            path, delay, branch or "default", exclude or [],
        )

    if not backups:
        logging.error("No valid directories to watch")
        sys.exit(1)

    # Sync any changes that happened while daemon was offline
    for backup in backups:
        backup.on_change()

    def shutdown(signum, frame):
        logging.debug("Received signal %d, shutting down", signum)
        sys.exit(0)

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)

    try:
        while True:
            signal.pause()
    except (KeyboardInterrupt, SystemExit):
        logging.info("Shutting down...")
        for observer in observers:
            observer.stop()
        for observer in observers:
            observer.join()
        sys.exit(0)


if __name__ == "__main__":
    main()
